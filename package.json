{
  "name": "bilibili-favlist",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Bilibili 视频收藏夹插件",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "wxt": "^0.20.18"
  }
}
